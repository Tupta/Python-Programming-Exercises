from asyncore import write


UC =1

zadania = []
zadania.append("posprzątaj pokój")
zadania.append("posprzątaj kuchnie")


def poka_zadania():
    zadanie_index = 0
    for zadanie in zadania:
        print(zadanie + " [" + str(zadanie_index) + "]")
        zadanie_index += 1

def dodaj_zadanie():
    zadanie = input("Podaj treść zadania:")
    zadania.append(zadanie)
    print("Zadanie zostało dodane")

def usun_zadanie():
    zadanie_index = int(input("Podaj indeks zadania do usunięcia: "))
    if zadanie_index < 0 or zadanie_index > len(zadania) - 1:
        print("Zadania nie ma na liście")
        return
    zadania.pop(zadanie_index)
    print("Usunięto zadanie!!!")
def zapisz_zadania_w_pliku():
    file = open("zadania.txt", "w")
    for zadanie in zadania:
        file.write(zadanie + "\n")
        file.close()


while UC != 5:
    if UC == 1:
        poka_zadania()
    
    
    if UC == 2:
        dodaj_zadanie
        
    if UC == 3:
        usun_zadanie

    if UC == 4:
        zapisz_zadania_w_pliku


    print("1. Pokaż zadanie")
    print("2. Dodaj zadania")
    print("3. Usuń zadanie")
    print("4. Zapisz zmiany do pliku")
    print("5. Wyjdź")
    
    print()
    UC = int(input("Co chcesz zrobi? Podaj liczbe:  "))
    print()

